# Clawpack Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# LLM API Keys
# ============================================
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_key_here

# ============================================
# Translation APIs (Langclaw)
# ============================================
GOOGLE_TRANSLATE_API_KEY=
DEEPL_API_KEY=
LIBRETRANSLATE_URL=http://localhost:5000

# ============================================
# Blockchain (TXclaw)
# ============================================
TX_BLOCKCHAIN_RPC=https://mainnet.txblockchain.com
TX_BLOCKCHAIN_TESTNET=https://testnet.txblockchain.com

# ============================================
# Medical APIs (Mediclaw)
# ============================================
NCBI_API_KEY=
FDA_API_KEY=

# ============================================
# Legal APIs (Lawclaw)
# ============================================
PACER_USERNAME=
PACER_PASSWORD=
COURTLISTENER_API_KEY=

# ============================================
# Server Configuration
# ============================================
WEBCLAW_PORT=5000
WEBCLAW_HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# Database (optional)
# ============================================
DATABASE_URL=sqlite:///clawpack.db
REDIS_URL=redis://localhost:6379
